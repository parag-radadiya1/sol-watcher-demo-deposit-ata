{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "paths": {
      "@langchain/core/messages": ["node_modules/@langchain/core/dist/messages/index.d.ts"],
      "@langchain/core/prompts": ["node_modules/@langchain/core/dist/prompts/index.d.ts"],
      "@langchain/core/output_parsers": ["node_modules/@langchain/core/dist/output_parsers/index.d.ts"],
      "@utils/*": ["src/utils/*"],
      "@db/*": ["src/db/*"],
      "@doc/*": ["src/doc/*"],
      "@helper/*": ["src/helper/*"],
      "@seeders/*": ["src/seeders/*"],
      "@guard/*": ["src/guards/*"],
      "@filter/*": ["src/filter/*"],
      "@config/*": ["src/config/*"],
      "@mail/*": ["src/app/mail/*"],
      "@app/*": ["src/app/*"],
      "@test/*": ["test/*"],
      "@entities/*": ["src/entities/*"],
      "@entities-user/*": ["src/entities/user/*"],
      "@entities-token/*": ["src/entities/token/*"],
      "@entities-otp/*": ["src/entities/otp/*"],
      "@entities-job/*": ["src/entities/job/*"],
      "@entities-marriage-match/*": ["src/entities/marriage-match/*"],
      "@entities-plan/*": ["src/entities/plan/*"],
      "@entities-message/*": ["src/entities/message/*"],
      "@entities-conversation/*": ["src/entities/conversation/*"],
      "@user-auth/*": ["src/app/user/auth/*"]
    }
  }
}
